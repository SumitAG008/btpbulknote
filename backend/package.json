{
  "name": "btpbulknote-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Bulk notification engine (birthdays/work anniversaries) - CAP Node.js",
  "license": "UNLICENSED",
  "scripts": {
    "start": "cds serve",
    "watch": "cds watch",
    "build": "cds build --production"
  },
  "dependencies": {
    "@sap/cds": "^8.7.3",
    "@sap-cloud-sdk/connectivity": "^3.24.0",
    "@sap-cloud-sdk/http-client": "^3.24.0",
    "better-sqlite3": "^11.3.0",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8.7.3"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "database": "db.sqlite"
        }
      }
    }
  }
}
